---
import Layout from "@/layout/layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import AboutCarrousel from "@/components/react/about-carrousel/about-carrousel";
import ImageDroplist from "@/components/droplist-with-image/image-droplist.astro";
import { TeamSlider } from "@/components/react/team-slider/team-slider";
const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
---

<Layout lang={lang}>
  <section class="pt-4 pb-24 bg-[#F6F6F6]">
    <article class="text-center">
      <h1 class="font-arvo text-3xl w-56 mx-auto leading-tight">
        {ui.about_page.hero.title}
      </h1>
      <img
        src="/assets/img/about/head-brain.gif"
        class="h-25 mx-auto mt-16 mb-12"
        alt="about"
      />
      <div class="font-light text-sm leading-tight">
        <p class="w-38 mx-auto">{ui.about_page.hero.description[0]}</p>
        <p class="w-42 mx-auto">{ui.about_page.hero.description[1]}</p>
      </div>
    </article>
  </section>

  <section>
    <AboutCarrousel client:visible slides={ui.about_page.slide.slides} />
  </section>

  <section class="text-center py-8 bg-[#F6F6F6]">
    <h1 class="font-arvo text-3xl w-56 mx-auto leading-tight">
      {ui.about_page.how_work.title}
    </h1>
  </section>

  <section>
    <ImageDroplist />
  </section>

  <TeamSlider
    client:visible
    title={ui.about_page.team.title}
    slides={ui.about_page.team.slides}
  />
</Layout>
