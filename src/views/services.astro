---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
---

<section class="bg-[#F3F3F3] py-20">
  <div class="lg:flex lg:container lg:mx-auto lg:items-center lg:px-3">
    <h1
      class="font-arvo text-3xl text-primary text-center w-60 mx-auto lg:text-6xl lg:w-120 lg:text-left lg:mx-0"
    >
      {
        ui.services.title.map((text, i) => (
          <span class={i == 1 ? "italic" : ""}>
            {text}
            <br />
          </span>
        ))
      }
    </h1>

    <video
      src={ui.services.videoPath}
      autoplay
      loop
      muted
      class="h-30 mx-auto my-18 lg:h-72 lg:my-0"></video>

    <article>
      <h2
        class="uppercase text-xl text-primary text-center font-semibold mb-4 lg:mb-10 lg:text-left"
      >
        {ui.services.services}
      </h2>

      <ul class="mx-auto w-min space-y-6.5 lg:space-y-9">
        {
          ui.services.items.map((item) => (
            <li class="flex flex-row w-45 justify-between items-center lg:w-57">
              <a
                href="/en/services"
                class="underline underline-offset-6 text-primary font-light text-lg lg:text-2xl lg:underline-offset-10 lg:decoration-1"
              >
                {item}
              </a>
              <img src="/assets/icons/arrow.svg" alt="->" class="lg:w-4" />
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>
