---
interface Props {
  pages: number[];
}
const { pages } = Astro.props;
---

<div
  class="bg-[#F6F6F6] px-6 py-1 flex flex-row gap-5 w-min mx-auto rounded-full mt-13 mb-8"
>
  {
    pages.map((page) => (
      <button class="text-[12px] size-4.5 hover:bg-primary hover:text-white transition-colors rounded-full flex items-center justify-center cursor-pointer">
        {page}
      </button>
    ))
  }
</div>
