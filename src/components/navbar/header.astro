---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Navitem from "./navitem.astro";

const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
const options = Object.values(ui.nav);
---

<header class="">
  <img src="/assets/icon.svg" alt="Logo NotAlias_" />
  <div
    id="menu-overlay"
    class="fixed inset-0 z-40 bg-[#D9D9D9]/80 md:hidden"
  >
  </div>
  <nav
    class="flex flex-col items-center gap-7 bg-black rounded h-[90dvh] w-[90dvw] -translate-x-1/2 absolute bottom-5 left-1/2 py-18 z-45"
  >
    <Navitem
      url={`${lang === "en" ? "/en" : ""}/`}
      label={"Home"}
      className="md:hidden"
    />
    {
      options.map((opt, i) => {
        return (
          <Navitem
            url={`${lang === "en" ? "/en" : ""}/${opt.toLowerCase()}`}
            label={opt}
            className={
              i === options.length - 1
                ? "text-primary hover:bg-white tracking-wider"
                : ""
            }
          />
        );
      })
    }
    <button>
      <img src="/assets/icons/plus.svg" alt="X" />
    </button>
  </nav>
</header>
