---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Navitem from "./navitem.astro";

const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
const options = Object.values(ui.nav);
---

<header class="sticky top-0 z-50 flex flex-row justify-between items-center px-4 py-10 lg:py-6">
  <div id="logo-wrapper" style="position: relative; width: 116px; height: 33px;">
    <img id="logo-icon" src="/assets/icon.svg" alt="Logo NotAlias_" />
    <img id="logo-wordmark" src="/assets/icons/notalias.svg" alt="NotAlias_" />
  </div>

  <!-- ? Navbar Desktop -->
  <nav
    class="hidden lg:flex lg:flex-row gap-3 items-center bg-black/10 px-8 py-2 rounded-full backdrop-blur-xl"
  >
    {
      options.map((opt, i) => {
        if (i === options.length - 1) return;

        return (
          <Navitem
            url={`${lang === "en" ? "/en" : ""}/${opt.toLowerCase()}`}
            label={opt}
          />
        );
      })
    }
  </nav>

  <!-- ? Navbar Mobile -->
  <div
    id="menu-overlay"
    class="fixed inset-0 z-40 bg-[#D9D9D9]/80 lg:hidden transition-opacity"
    data-is-active="false"
  >
    <nav
      class="flex flex-col items-center gap-7 bg-black rounded-lg h-[90dvh] w-[90dvw] -translate-x-1/2 absolute bottom-5 left-1/2 py-18"
    >
      <Navitem
        url={`${lang === "en" ? "/en" : ""}/`}
        label={"Home"}
        className="md:hidden"
      />
      {
        options.map((opt, i) => {
          return (
            <Navitem
              url={`${lang === "en" ? "/en" : ""}/${opt.toLowerCase()}`}
              label={opt}
              className={
                i === options.length - 1
                  ? "text-primary hover:bg-white tracking-wider"
                  : ""
              }
            />
          );
        })
      }
      <button id="close-menu">
        <img src="/assets/icons/plus.svg" alt="X" />
      </button>
    </nav>
  </div>
  <button
    id="open-menu"
    class="bg-primary py-0.5 px-2.75 rounded-full uppercase text-white text-sm lg:hidden"
  >
    {ui.menu}
  </button>

  <a
    href={`${lang === "en" ? "/" : "/en"}`}
    class="hidden lg:block text-sm tracking-wide"
  >
    ES | EN
  </a>
</header>

<style is:inline>
  #menu-overlay.active {
    opacity: 1;
    pointer-events: all;
  }

  #menu-overlay:not(.active) {
    opacity: 0;
    pointer-events: none;
  }

  #logo-icon,
  #logo-wordmark {
    position: absolute;
    left: 0;
    top: 50%;
    transition:
      opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #logo-icon {
    transform: translateY(-50%) scale(1);
    opacity: 1;
  }

  #logo-wordmark {
    transform: translateY(calc(-50% + 8px));
    opacity: 0;
  }

  #logo-wrapper.scrolled #logo-icon {
    transform: translateY(calc(-50% - 8px)) scale(0.85);
    opacity: 0;
  }

  #logo-wrapper.scrolled #logo-wordmark {
    transform: translateY(-50%);
    opacity: 1;
  }
</style>

<script>
  const menu = document.querySelector("#menu-overlay") as HTMLDivElement;
  const openBtn = document.querySelector("#open-menu") as HTMLButtonElement;
  const closeBtn = document.querySelector("#close-menu") as HTMLButtonElement;

  const toggleMenu = () => {
    if (menu.getAttribute("data-is-active") === "false") {
      menu.classList.remove("hidden");
      menu.classList.add("active");
      menu.setAttribute("data-is-active", "true");
    } else {
      menu.classList.remove("active");
      menu.setAttribute("data-is-active", "false");
      setTimeout(() => {
        menu.classList.add("hidden");
      }, 150);
    }
  };

  openBtn?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", toggleMenu);

  const logoWrapper = document.querySelector("#logo-wrapper") as HTMLDivElement;

  window.addEventListener("scroll", () => {
    logoWrapper.classList.toggle("scrolled", window.scrollY > 60);
  }, { passive: true });
</script>
