---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
---

<footer class="relative px-4 pt-8 pb-5">
  <video
    src="/assets/videos/footer.mp4"
    autoplay
    muted
    loop
    class="absolute inset-0 w-full h-full object-cover z-0"></video>
  <article class="relative z-10 text-white grid grid-cols-2 gap-2 items-start">
    <div class="grid gap-y-3">
      <div class="w-44">
        <h1 class="footer-s-title">{ui.footer.contact_us.title}</h1>
        {
          ui.footer.contact_us.texts.map((t) => (
            <p class="footer-s-text">{t}</p>
          ))
        }
      </div>

      <div class="w-44">
        <h1 class="footer-s-title">{ui.footer.guadalajara.title}</h1>
        <p class="footer-s-text">{ui.footer.guadalajara.address}</p>
      </div>

      <div class="w-44">
        <h1 class="footer-s-title">{ui.footer.madrid.title}</h1>
        <p class="footer-s-text">{ui.footer.madrid.address}</p>
      </div>

      <div class="w-44 mt-3">
        <h1 class="footer-s-title">{ui.footer.los_angeles.title}</h1>
        {
          ui.footer.los_angeles.address.map((t) => (
            <p class="footer-s-text">{t}</p>
          ))
        }
        <p class="footer-s-text">{ui.footer.los_angeles.phone}</p>
      </div>

      <p class="w-42 mt-8 footer-s-text">
        {
          ui.footer.copyright.map((ext) => {
            return ext === "year" ? (
              <span id="footer-year">{ext}</span>
            ) : (
              <span>{ext}</span>
            );
          })
        }
      </p>
    </div>

    <div class="grid gap-y-3">
      <div>
        <h1 class="footer-s-title">{ui.footer.social.title}</h1>
        <p class="footer-s-text">{ui.footer.social.instagram.label}</p>
        <p class="footer-s-text">{ui.footer.social.linkedin.label}</p>
        <p class="footer-s-text">{ui.footer.social.behance.label}</p>
      </div>

      <div class="mt-3">
        <h1 class="footer-s-title">{ui.footer.menu.label}</h1>
        <p class="footer-s-text">{ui.footer.menu.home.label}</p>
        <p class="footer-s-text">{ui.footer.menu.work.label}</p>
        <p class="footer-s-text">{ui.footer.menu.services.label}</p>
        <p class="footer-s-text">{ui.footer.menu.about.label}</p>
        <p class="footer-s-text">{ui.footer.menu.contact.label}</p>
      </div>
    </div>
  </article>
</footer>

<style>
  @reference "@/styles/global.css";

  .footer-s-title {
    @apply text-[12px] uppercase mb-0.5;
  }

  .footer-s-text {
    @apply text-[12px] font-light leading-3.5;
  }
</style>

<script>
  const yearEl = document.getElementById("footer-year") as HTMLSpanElement;

  yearEl.textContent = new Date().getFullYear().toString() + " ©";
</script>
